# =============================================================================
# Locus News-Agents - .env.example
# =============================================================================
# Copier vers `.env` et remplir les cles. Le fichier `.env` est gitignore.
# Toutes les variables ci-dessous ont des defauts raisonnables sauf les
# 3 cles API obligatoires en haut.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CLES API LLM (OBLIGATOIRES & OPTIONNELLES)
# -----------------------------------------------------------------------------

# Description : Incarne l'agent Baissier (avocat du diable) via Llama-4-Scout-17b
# Obtention : https://console.groq.com (Création de compte gratuit, quotas très larges)
GROQ_API_KEY=your_groq_api_key_here

# Description : Incarne l'agent Haussier via Llama-3.3-70b
# Obtention : https://cloud.cerebras.ai (Création de compte gratuit, quotas généreux)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Description : Incarne l'agent Neutre (arbitre final) via mistral-small-latest
# Obtention : https://console.mistral.ai (Compte développeur requis avec CB, coût très faible < $1/mois pour tester)
MISTRAL_API_KEY=your_mistral_api_key_here

# Description : (Optionnel) LLM de fallback et pour l'audit approfondi (ReasoningAuditor / HighQualityConsensus)
# Obtention : https://build.nvidia.com (Tier gratuit : 1000 crédits offerts, amplement suffisant)
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# OPTIONNEL : Active le ReasoningAuditor (audit post-debat via Qwen3-thinking).
# 1 = active, 0 = inactif (defaut). Cf. ADR-015. Recommande pour audit hebdo
# uniquement (latence 30s par audit, ne PAS activer dans le pipeline live).
ENABLE_REASONING_AUDITOR=0

# OPTIONNEL : Active le HighQualityConsensus (second avis via Llama-3.1-405B
# sur les decisions HIGH_RISK, typiquement 1-5/jour). Cf. ADR-016.
# Necessite NVIDIA_NIM_API_KEY. Latence 21-110s par appel.
ENABLE_HIGH_QUALITY_CONSENSUS=0

# -----------------------------------------------------------------------------
# 2. CLES API DONNEES (OPTIONNELLES, fallback yfinance)
# -----------------------------------------------------------------------------

# Description : (Optionnel) Flux earnings calendar temps-réel (sinon fallback scraping yfinance)
# Obtention : https://finnhub.io (Tier gratuit basique suffisant)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Description : (Optionnel) Contexte macro (taux Fed, treasury yields). Si absent -> yfinance
# Obtention : https://fred.stlouisfed.org/docs/api/api_key.html (Totalement gratuit, demande simple)
FRED_API_KEY=your_fred_api_key_here

# -----------------------------------------------------------------------------
# 3. PATHS RUNTIME
# -----------------------------------------------------------------------------
DATABASE_PATH=data/news_database.db
LOGS_DIR=logs
REPORTS_DIR=reports

# -----------------------------------------------------------------------------
# 4. CACHES / PERFORMANCE
# -----------------------------------------------------------------------------
# Taille max du cache LRU ABSA (hash du contenu -> resultat).
ABSA_CACHE_MAX=256
# TTL du cache contexte macro (VIX, SPY, Fed). 15min = 900s par defaut.
MACRO_CONTEXT_TTL_SEC=900

# -----------------------------------------------------------------------------
# 5. POSITION SIZING - Kelly net de frais (Medo-Pignatti 2013)
# -----------------------------------------------------------------------------
# Penalite anti-incertitude : f_applied = f_kelly / (1 + kappa * Var)
KELLY_UNCERTAINTY_KAPPA=4.0
# Clamp de la probabilite p (evite divergences quand p tres haut/bas).
KELLY_F_CLAMP_MIN=0.15
KELLY_F_CLAMP_MAX=0.85

# -----------------------------------------------------------------------------
# 6. REGIMES DE MARCHE (vol-adjusted, sigma_20d)
# -----------------------------------------------------------------------------
# Sideways : |return_20d| < seuil ET sigma_20d < seuil
REGIME_SIDEWAYS_RETURN_ABS=0.02
REGIME_SIDEWAYS_VOL_MAX=0.015
# High-vol : sigma_20d > seuil
REGIME_HIGH_VOL_THRESHOLD=0.025

# -----------------------------------------------------------------------------
# 7. COUNTERFACTUAL INVARIANCE (Veitch et al. 2021)
# -----------------------------------------------------------------------------
# Score CI : 0.90 = robuste, < 0.75 = LLM triche via priors.
CI_SCORE_ALERT_THRESHOLD=0.75
CI_SCORE_GOOD_THRESHOLD=0.90

# -----------------------------------------------------------------------------
# 8. CALIBRATION (Platt + Isotonic, Guo 2017)
# -----------------------------------------------------------------------------
# ECE cible apres re-calibration nocturne.
ECE_TARGET_POST_CALIBRATION=0.05

# -----------------------------------------------------------------------------
# 9. EXECUTION COSTS (Almgren-Chriss 2001 - opt-in)
# -----------------------------------------------------------------------------
# Almgren-Chriss n'est applique que si Q/ADV > seuil (default 0.5%).
# Pour du retail < 100k USD, le mode "cheap" (commissions IB + spread) suffit.
ALMGREN_CHRISS_AUTO_TRIGGER_ADV_PCT=0.005

# -----------------------------------------------------------------------------
# 10. FEATURE FLAGS (1=ON, 0=OFF)
# -----------------------------------------------------------------------------
ENABLE_TEMPORAL_FENCE=1
ENABLE_BAYESIAN_AGGREGATOR=1
ENABLE_POSITION_SIZER=1
# EVAL_ANONYMIZE : active l'anonymizer en mode audit (ticker_swap pour CI score).
EVAL_ANONYMIZE=0

# -----------------------------------------------------------------------------
# 11. GARDE-FOUS OPERATIONNELS (Phase 3)
# -----------------------------------------------------------------------------
# DRY_RUN : paper trading. 1 -> JSONL append-only, zero mutation portefeuille.
DRY_RUN=0
DRY_RUN_LOG_PATH=logs/dry_run_trades.jsonl

# Kill-switch VIX (Whaley 2009). VIX >= seuil -> tous signaux forces HOLD_SYSTEMIC.
VIX_KILL_SWITCH_THRESHOLD=45.0

# Budget LLM quotidien (USD). Depassement -> BudgetExceededError, interrupt propre.
# 0 = desactive le garde-fou (NON RECOMMANDE en mode autopilot).
LLM_DAILY_BUDGET_USD=5.0
LLM_COST_LOG_DIR=reports/llm_cost_daily

# Cap sectoriel (DeMiguel-Garlappi-Uppal 2009). 0.30 = 30% max par secteur.
MAX_SECTOR_EXPOSURE_PCT=0.30

# -----------------------------------------------------------------------------
# 12. CONTRAINTES CROSS-ASSET
# -----------------------------------------------------------------------------
# Refuse une nouvelle position si correlation rolling 60d > seuil avec une
# position existante (anti-redundance).
MAX_PAIRWISE_CORRELATION=0.80
CORRELATION_LOOKBACK_DAYS=60

# -----------------------------------------------------------------------------
# 13. EXECUTION / BROKER (cf. src/execution/, ADR-011)
# -----------------------------------------------------------------------------
# Backend broker : "dry_run" (defaut, JSONL append-only) ou "alpaca" (paper trading).
BROKER_BACKEND=dry_run

# Description : (Optionnel) Clé publique pour le paper-trading via Alpaca. Utilisée si BROKER_BACKEND=alpaca.
# Obtention : https://alpaca.markets (Mode paper-trading 100% gratuit)
ALPACA_API_KEY=your_alpaca_api_key_here

# Description : (Optionnel) Clé secrète pour le paper-trading via Alpaca.
# Obtention : https://alpaca.markets
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# 1 = paper trading sandbox (recommande), 0 = compte reel (DANGER).
ALPACA_PAPER=1

# -----------------------------------------------------------------------------
# 14. LOGGING (cf. src/utils/logger.py)
# -----------------------------------------------------------------------------
# Niveau global : DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Format : "human" (lisible terminal) ou "json" (logs structures pour aggregation).
LOG_FORMAT=human

# Rotation des logs (RotatingFileHandler).
# LOG_FILE active l ecriture dans un fichier avec rotation automatique.
# Defauts : 10 Mo par fichier x 5 backups = 50 Mo max. Recommande en production.
LOG_FILE=logs/pipeline.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5
